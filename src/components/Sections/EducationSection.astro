---
import EducationCard from "@/components/Cards/ResumeCard.astro";
import getCollectionWithLocale from "@/utils/getCollectionWithLocale";
const aboutSnippets = await getCollectionWithLocale(
  "aboutSnippets",
  Astro.currentLocale ?? "en",
);
const educations = aboutSnippets
  .filter((entry) => entry.id.includes("education"))
  .sort((a, b) => a.data.order - b.data.order);
---

{
  educations.map(({ data: education }) => {
    return (
      <EducationCard
        timespan={education.timeline}
        title={education.title}
        organization={education.organization}
      />
    );
  })
}
